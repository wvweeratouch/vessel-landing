---
import Base from './Base.astro';
const { frontmatter } = Astro.props;
---
<Base title={`${frontmatter.title} — Vessel 📦`} description={frontmatter.excerpt}>
  <div class="mb-8">
    <a href="/blog" class="text-sm text-zinc-500 hover:text-zinc-300">← blog</a>
  </div>
  <article>
    <div class="text-xs text-zinc-600 mb-2">{frontmatter.date} · <span class="text-zinc-500">{frontmatter.tag}</span></div>
    <div class="prose prose-invert prose-zinc prose-sm max-w-none
      prose-headings:text-zinc-100 prose-headings:font-bold
      prose-h1:text-2xl prose-h1:text-amber-400 prose-h1:mb-6
      prose-h2:text-lg prose-h2:mt-8 prose-h2:mb-3
      prose-p:text-zinc-400 prose-p:leading-relaxed
      prose-a:text-amber-400 prose-a:no-underline hover:prose-a:text-amber-300
      prose-code:text-amber-300 prose-code:bg-zinc-900 prose-code:px-1 prose-code:py-0.5 prose-code:rounded prose-code:text-xs
      prose-pre:bg-zinc-900 prose-pre:border prose-pre:border-zinc-800
      prose-strong:text-zinc-200
      prose-table:text-sm prose-th:text-zinc-300 prose-td:text-zinc-400
      prose-blockquote:border-amber-400 prose-blockquote:text-zinc-400
      prose-hr:border-zinc-800
    ">
      <slot />
    </div>
  </article>
</Base>
